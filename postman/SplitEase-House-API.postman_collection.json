{
  "info": {
    "_postman_id": "8a364a72-6fef-4e79-bf4c-d80c462b0ac2",
    "name": "SplitEase House API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing SplitEase auth + house module APIs."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const rawUrl = pm.request.url.toString();",
          "const authExclusions = ['/auth/register', '/auth/login', '/auth/verify-email', '/auth/forget-password', '/auth/reset-password', '/auth/login/google', '/auth/google/success', '/auth/oauth/error'];",
          "const shouldSkipCookie = authExclusions.some((path) => rawUrl.includes(path));",
          "if (!shouldSkipCookie) {",
          "  const accessToken = pm.collectionVariables.get('accessToken') || pm.environment.get('accessToken');",
          "  const sessionToken = pm.collectionVariables.get('sessionToken') || pm.environment.get('sessionToken');",
          "  if (accessToken && sessionToken) {",
          "    pm.request.headers.upsert({ key: 'Cookie', value: `accessToken=${accessToken}; better-auth.session_token=${sessionToken}` });",
          "  }",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "let json = null;",
          "try { json = pm.response.json(); } catch (e) {}",
          "if (json?.data?.accessToken) {",
          "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
          "  pm.environment.set('accessToken', json.data.accessToken);",
          "}",
          "if (json?.data?.token) {",
          "  pm.collectionVariables.set('sessionToken', json.data.token);",
          "  pm.environment.set('sessionToken', json.data.token);",
          "}",
          "if (json?.data?.id && pm.request.url.toString().includes('/houses')) {",
          "  pm.collectionVariables.set('houseId', json.data.id);",
          "  pm.environment.set('houseId', json.data.id);",
          "}",
          "if (Array.isArray(json?.data) && json.data.length > 0 && json.data[0]?.id && pm.request.url.toString().includes('/houses')) {",
          "  pm.collectionVariables.set('houseId', json.data[0].id);",
          "  pm.environment.set('houseId', json.data[0].id);",
          "}",
          "pm.test('Status code is not server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
