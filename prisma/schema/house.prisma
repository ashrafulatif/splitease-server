model House {
  id          String   @id @default(uuid())
  name        String
  description String?

  createdBy   String
  creator     User     @relation("HouseCreator", fields: [createdBy], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members     HouseMember[]
  months      Month[]
  deposits    Deposit[]
  expenses    Expense[]
  meals       Meal[]
}